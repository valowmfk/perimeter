[Unit]
Description=Perimeter Automation Platform (Test Instance)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mklouda
Group=mklouda

ExecStart=/usr/bin/python3 -u /home/mklouda/automation-demo/qbranch_app.py
WorkingDirectory=/home/mklouda/automation-demo

# SOPS decryption key (needed for config.py import even if features are disabled)
Environment=SOPS_AGE_KEY_FILE=/home/mklouda/.config/sops/age/keys.txt

# Feature toggles — all optional modules disabled for testing
Environment=FLASK_PORT=8081
Environment=PERIMETER_FEATURE_ANSIBLE=0
Environment=PERIMETER_FEATURE_CERTS=0
Environment=PERIMETER_FEATURE_DNS=0
Environment=PERIMETER_FEATURE_IPAM=0
Environment=PERIMETER_FEATURE_VTHUNDER=0
Environment=PERIMETER_FEATURE_AUDIT=0

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=perimeter-test

# Graceful shutdown
KillSignal=SIGTERM
TimeoutStopSec=30

# Restart on failure
Restart=on-failure
RestartSec=5

# Security hardening
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/mklouda/automation-demo
ReadWritePaths=/home/mklouda/.ssh

[Install]
WantedBy=multi-user.target
