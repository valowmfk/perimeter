{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(perimeter_http_requests_total[5m])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Error Rate (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(perimeter_http_requests_total{status=~\"4..|5..\"}[5m]))",
          "legendFormat": "Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(perimeter_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(perimeter_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(perimeter_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Active Operations",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "expr": "perimeter_vm_provisions_active",
          "legendFormat": "VM Provisions",
          "refId": "A"
        },
        {
          "expr": "perimeter_playbook_runs_active",
          "legendFormat": "Playbook Runs",
          "refId": "B"
        }
      ]
    },
    {
      "title": "VM Provisioning",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*|.*error.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(perimeter_vm_provisions_total[1h])",
          "legendFormat": "{{vm_type}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Playbook Runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(perimeter_playbook_runs_total[1h])",
          "legendFormat": "{{playbook}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cert & VIP Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*|.*error.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(perimeter_cert_deploys_total[1h])",
          "legendFormat": "Cert Deploy - {{status}}",
          "refId": "A"
        },
        {
          "expr": "increase(perimeter_vip_operations_total[1h])",
          "legendFormat": "VIP {{action}} - {{status}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Template Refreshes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(perimeter_template_refreshes_total[1h])",
          "legendFormat": "{{template}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Endpoints by Request Count",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "Value" }] },
      "targets": [
        {
          "expr": "topk(15, sum by (endpoint) (increase(perimeter_http_requests_total[24h])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "endpoint": "Endpoint", "Value": "Requests (24h)" } } }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["perimeter", "automation"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Perimeter - Automation Platform",
  "uid": "perimeter-overview",
  "version": 1
}
