# =============================================
# Perimeter Automation Platform — Secrets
# Generated by installer on {{ timestamp }}
# Encrypted with SOPS + Age
# =============================================

# ── Proxmox API ──────────────────────────────
PM_API_URL={{ pm_api_url }}
PM_API_TOKEN_ID={{ pm_api_token_id }}
PM_API_TOKEN_SECRET={{ pm_api_token_secret }}

# ── SSH Keys (public keys for cloud-init) ────
LINUX_SSH_USER={{ ssh_user }}
{% for i, key in enumerate(ssh_public_keys, 1) %}
LINUX_SSH_KEY_{{ i }}={{ key }}
{% endfor %}

# ── vThunder / ACOS ──────────────────────────
{% if features.get('vthunder', False) %}
VTH_ADMIN_PASS={{ vth_admin_pass }}
VTH_SSH_PUBKEY_PATH={{ vth_ssh_pubkey_path }}
QBRANCH_IP={{ perimeter_ip }}
{% endif %}

# ── Pi-hole DNS ──────────────────────────────
{% if features.get('dns', False) %}
PIHOLE_API_URL={{ pihole_api_url }}
PIHOLE_API_PASSWORD={{ pihole_api_password }}
{% endif %}

# ── Netbox IPAM ──────────────────────────────
{% if features.get('ipam', False) %}
NETBOX_URL={{ netbox_url }}
NETBOX_API_TOKEN={{ netbox_api_token }}
{% endif %}

# ── Loki Audit ───────────────────────────────
{% if features.get('audit', False) %}
LOKI_URL={{ loki_url }}
{% endif %}

# ── Certbot ──────────────────────────────────
{% if features.get('certificates', False) %}
CERTBOT_EMAIL={{ certbot_email }}
{% endif %}
