[Unit]
Description=Perimeter Automation Platform
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ service_user }}
Group={{ service_user }}

ExecStart=/usr/bin/python3 -u {{ install_dir }}/qbranch_app.py
WorkingDirectory={{ install_dir }}

# SOPS decryption needs the Age private key
Environment=SOPS_AGE_KEY_FILE={{ age_key_path }}

# Feature toggles
{% for feature, enabled in features.items() %}
Environment=PERIMETER_FEATURE_{{ feature | upper }}={{ '1' if enabled else '0' }}
{% endfor %}

# Flask port
Environment=FLASK_PORT={{ flask_port }}

# DNS domain
Environment=PERIMETER_DNS_DOMAIN={{ dns_domain }}

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=perimeter

# Graceful shutdown — allow running terraform/ansible to finish
KillSignal=SIGTERM
TimeoutStopSec=90

# Restart on failure, but not on clean exit
Restart=on-failure
RestartSec=5

# Security hardening
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths={{ install_dir }}
ReadWritePaths={{ home_dir }}/.ssh
{% if features.get('certificates', False) %}
ReadWritePaths={{ docker_compose_dir }}
{% endif %}

[Install]
WantedBy=multi-user.target
